{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
  "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2020",
    "outDir": "../../dist/apps/api",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "common/*": ["src/common/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["**/*.spec.ts", "test", "dist", "node_modules"]
}
