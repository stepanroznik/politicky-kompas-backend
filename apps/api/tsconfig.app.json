{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2020",
    "incremental": true,
    "outDir": "../../dist/out-tsc",
  },
  "include": ["src"],
  "exclude": ["**/*.spec.ts", "test", "node_modules"]
}
